{
  "name": "blink-mcp",
  "version": "2.0.0",
  "description": "Unified Blink MCP Server with CMS and Web tools",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "blink-mcp": "dist/index.js",
    "blink-mcp-http": "dist/http-server.js"
  },
  "scripts": {
    "build": "bun run tsc",
    "dev": "bun run src/index.ts",
    "dev:http": "bun run src/http-server.ts",
    "start": "bun run dist/http-server.js",
    "start:stdio": "bun run dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.1",
    "cors": "^2.8.5",
    "diff": "^8.0.0",
    "exa-js": "^1.4.2",
    "express": "^4.21.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/cors": "^2.8.17",
    "@types/diff": "^8.0.0",
    "@types/express": "^5.0.0",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
