{
  "name": "@blink-mcp/cms",
  "version": "1.0.0",
  "description": "MCP server for Blink CMS content management",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "blink-cms-mcp": "dist/index.js",
    "blink-cms-mcp-http": "dist/http-server.js"
  },
  "scripts": {
    "build": "bun run tsc",
    "dev": "bun run src/index.ts",
    "dev:http": "bun run src/http-server.ts",
    "start": "bun run dist/index.js",
    "start:http": "bun run dist/http-server.js",
    "test": "bun test",
    "test:watch": "bun test --watch"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.1",
    "cors": "^2.8.5",
    "diff": "8",
    "express": "^4.21.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/cors": "^2.8.17",
    "@types/diff": "^8.0.0",
    "@types/express": "^5.0.0",
    "typescript": "^5.7.2"
  }
}
